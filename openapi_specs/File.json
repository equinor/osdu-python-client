            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "otherRelevantDataCountries": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 1,
            "uniqueItems": true
          },
          "status": {
            "type": "string",
            "enum": [
              "compliant",
              "incompliant"
            ]
          }
        },
        "required": [
