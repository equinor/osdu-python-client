  "components": {
    "schemas": {
      "AppError": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "format": "int32"
          },
          "reason": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      },
      "Acl": {
        "type": "object",
        "properties": {
          "viewers": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "owners": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "Ancestry": {
        "type": "object",
        "description": "A named list of entities in the data lake as a dictionary item.",
        "properties": {
          "parents": {
            "type": "array",
            "description": "An array of one or more entity references in the data lake.",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "DatasetProperties": {
        "type": "object",
        "description": "Dataset Properties",
        "properties": {
          "FileSourceInfo": {
            "$ref": "#/components/schemas/FileSourceInfo"
          }
        },
        "required": [
          "FileSourceInfo"
        ]
      },
      "FileData": {
        "type": "object",
        "description": "The file data container containing all necessary details of the file record",
        "properties": {
          "Name": {
            "type": "string",
            "description": "An optional name of the dataset, e.g. a user friendly file or file collection name."
          },
          "Description": {
            "type": "string",
            "description": "An optional, textual description of the dataset."
          },
          "TotalSize": {
            "type": "string",
            "description": "Total size of the dataset in bytes; for files it is the same as declared in FileSourceInfo.FileSize or the sum of all individual files. Implemented as string. The value must be convertible to a long integer (sizes can become very large).",
            "pattern": "^[0-9]+$"
          },
          "EncodingFormatTypeID": {
            "type": "string",
            "description": "Encoding Format Type ID",
            "pattern": "^srn:<namespace>:reference-data\\\\/EncodingFormatType:[^:]+:[0-9]*$"
          },
          "SchemaFormatTypeID": {
            "type": "string",
            "description": "Schema Format Type ID",
            "pattern": "^srn:<namespace>:reference-data\\\\/SchemaFormatType:[^:]+:[0-9]*$"
          },
          "ResourceHomeRegionID": {
            "type": "string",
            "description": "Resource Home Region ID"
          },
          "ResourceHostRegionIDs": {
            "type": "array",
            "description": "Resource Host Region IDs",
            "items": {
              "type": "string"
            }
          },
          "ResourceCurationStatus": {
            "type": "string",
            "description": "Resource Curation Status"
          },
          "ResourceLifecycleStatus": {
            "type": "string",
            "description": "Resource Lifecycle Status"
          },
          "ResourceSecurityClassification": {
            "type": "string",
            "description": "Resource Security Classification"
          },
          "Source": {
            "type": "string",
            "description": "Source"
          },
          "DatasetProperties": {
            "$ref": "#/components/schemas/DatasetProperties"
          },
          "ExistenceKind": {
            "type": "string",
            "description": "Existence Kind"
          },
          "Endian": {
            "type": "string",
            "description": "Endianness of binary value. Enumeration- \\BIG\\ \\LITTLE\\.  If absent applications will need to interpret from context indicators.",
            "enum": [
              "BIG",
              "LITTLE"
            ]
          },
          "Checksum": {
            "type": "string",
            "description": "MD5 checksum of file bytes - a 32 byte hexadecimal number",
            "pattern": "^[0-9a-fA-F]32}$"
          },
          "ExtensionProperties": {
            "type": "object",
            "additionalProperties": {},
            "description": "File DMS Extension Properties"
          }
        },
        "required": [
          "DatasetProperties"
        ]
      },
      "FileMetadata": {
        "type": "object",
        "description": "File metadata record.",
        "properties": {
