            "type": "string",
            "description": "Kind of data being ingested. Must follow the naming\n  convention:data-Partition-Id}:dataset-name}:record-type}:version}.",
            "example": "osdu:wks:dataset--File.Generic:1.0.0"
          },
          "legal": {
            "$ref": "#/components/schemas/Legal"
          },
